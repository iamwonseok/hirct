// Test --preprocess flag parsing and validation
//
// RUN: %hirct-gen --help 2>&1 | %FileCheck %s --check-prefix=CHECK-HELP
// RUN: not %hirct-gen --preprocess invalid dummy.mlir -o %t 2>&1 | %FileCheck %s --check-prefix=CHECK-INVALID
//
// CHECK-HELP: --preprocess <mode>
// CHECK-HELP: Preprocessing mode: none, verilator
// CHECK-INVALID: error: unknown preprocess mode 'invalid' (expected: none, verilator)
