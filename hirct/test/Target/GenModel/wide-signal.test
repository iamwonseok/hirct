// Test GenModel: wide-signal module with 34 ports (medium-size diversity gate)
//
// RUN: %hirct-gen %S/../../fixtures/WideSignal.mlir -o %t --only model
// RUN: cat %t/cmodel/WideSignal.h | %FileCheck %s --check-prefix=CHECK-H
// RUN: cat %t/cmodel/WideSignal.cpp | %FileCheck %s --check-prefix=CHECK-CPP
//
// CHECK-H: AUTO-GENERATED
// CHECK-H: class WideSignal
// CHECK-H: uint64_t data_a
// CHECK-H: uint64_t mask
// CHECK-H: uint16_t en
// CHECK-H: uint32_t threshold
// CHECK-H: uint64_t data_out
// CHECK-H: uint16_t status
// CHECK-H: bool valid
//
// CHECK-CPP: AUTO-GENERATED
// CHECK-CPP: void WideSignal::eval_comb()
