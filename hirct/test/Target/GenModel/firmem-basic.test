// Test GenModel: seq.firmem with read and write ports
//
// RUN: %hirct-gen %S/../../fixtures/FirmemBasic.mlir -o %t --only model
// RUN: cat %t/cmodel/FirmemBasic.h | %FileCheck %s --check-prefix=CHECK-H
// RUN: cat %t/cmodel/FirmemBasic.cpp | %FileCheck %s --check-prefix=CHECK-CPP
//
// CHECK-H: AUTO-GENERATED
// CHECK-H: class FirmemBasic
// CHECK-H: uint16_t rd_data
// CHECK-H: uint16_t mem_{{.*}}[16]
// CHECK-H: size_t mem_wp_addr_0
// CHECK-H: uint16_t mem_wp_data_0
// CHECK-H: bool mem_wp_en_0
// CHECK-H: uint16_t mem_rp_data_0
//
// CHECK-CPP: AUTO-GENERATED
// CHECK-CPP: void FirmemBasic::eval_comb()
// CHECK-CPP: mem_wp_addr_0
// CHECK-CPP: mem_wp_data_0
// CHECK-CPP: mem_wp_en_0
// CHECK-CPP: void FirmemBasic::step()
// CHECK-CPP: mem_rp_data_0 =
// CHECK-CPP: if (mem_wp_en_0)
