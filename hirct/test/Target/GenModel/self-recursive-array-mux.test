// Test: self-recursive array muxes must preserve the mux condition in emitted
// C++ rather than collapsing to the updated or hold branch.
//
// RUN: %hirct-gen %S/../../fixtures/SelfRecursiveArrayMux.mlir -o %t --only model 2>&1 | %FileCheck %s --check-prefix=WARN
// RUN: %FileCheck %s --input-file %t/cmodel/SelfRecursiveArrayMux.cpp --check-prefix=CPP
// RUN: g++ -std=c++17 -c %t/cmodel/SelfRecursiveArrayMux.cpp -I %t/cmodel -o /dev/null
//
// WARN-NOT: val map miss
//
// CPP: uint8_t [[UPDATED:t[0-9]+]][4];
// CPP: for (int __i = 0; __i < 4; ++__i) [[UPDATED]][__i] = reg_ssa_reg[__i];
// CPP: [[UPDATED]][static_cast<size_t>(index) % 4] = static_cast<uint8_t>(data);
// CPP: uint8_t [[MUX:t[0-9]+]][4];
// CPP-NEXT: for (int __i = 0; __i < 4; ++__i) [[MUX]][__i] = (reg_ssa_en__reg) ? [[UPDATED]][__i] : reg_ssa_reg[__i];
// CPP: uint8_t [[OUT:t[0-9]+]] = static_cast<uint8_t>(((static_cast<size_t>(index) < 4 ? [[MUX]][static_cast<size_t>(index)] : 0)) & ((1ULL << 8) - 1ULL));
// CPP: for (unsigned __k = 0; __k < 4; ++__k) next_ssa_reg[__k] = static_cast<uint8_t>([[MUX]][__k]);
// CPP: out = static_cast<uint8_t>(([[OUT]]) & ((1ULL << 8) - 1ULL));
