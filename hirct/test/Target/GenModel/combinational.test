// Test GenModel: pure combinational module (no clock/reset ports)
//
// RUN: %hirct-gen %S/../../fixtures/CombOnly.mlir -o %t --only model
// RUN: cat %t/cmodel/CombOnly.h | %FileCheck %s --check-prefix=CHECK-H
// RUN: cat %t/cmodel/CombOnly.cpp | %FileCheck %s --check-prefix=CHECK-CPP
//
// CHECK-H: AUTO-GENERATED
// CHECK-H: class CombOnly
// CHECK-H-NOT: clock
// CHECK-H: void eval_comb();
//
// CHECK-CPP: AUTO-GENERATED
// CHECK-CPP: void CombOnly::eval_comb()
// CHECK-CPP: sel
// CHECK-CPP: a
// CHECK-CPP: b
// CHECK-CPP: y =
