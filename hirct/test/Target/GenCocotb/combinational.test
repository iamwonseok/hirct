// Test GenCocotb: Python testbench generation for combinational-only module
//
// RUN: %hirct-gen %S/../../fixtures/RVCExpander.mlir -o %t --only cocotb
// RUN: python3 -m py_compile %t/cocotb/test_Fadu_K2_S5_RVCExpander.py
// RUN: cat %t/cocotb/test_Fadu_K2_S5_RVCExpander.py | %FileCheck %s
//
// CHECK: AUTO-GENERATED
// CHECK: import cocotb
// CHECK: from cocotb.clock import Clock
// CHECK: @cocotb.test()
// CHECK: async def test_reset
// CHECK-NOT: Clock(dut.
// CHECK: Timer(1, units="ns")
// CHECK: @cocotb.test()
// CHECK: async def test_random_stimulus
// CHECK: random.getrandbits(32)
// CHECK-NOT: RisingEdge
// CHECK: Timer(1, units="ns")
